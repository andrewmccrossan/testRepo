<div class="card h-100">
  <div class="card-body">
    <h5 class="card-title"><%= link_to board.name, board_path(board), class: "text-decoration-none" %></h5>
    <p class="card-text text-muted"><%= truncate(board.description, length: 100) %></p>
  </div>
  <div class="card-footer d-flex justify-content-between align-items-center">
    <small class="text-muted"><%= board.tasks.count %> tasks</small>
    <small class="text-muted">by <%= board.owner.name %></small>
  </div>
</div>
