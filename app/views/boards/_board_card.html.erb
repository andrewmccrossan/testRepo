<%= link_to board_path(board), class: "text-decoration-none" do %>
  <div class="card h-100">
    <div class="card-body">
      <h5 class="card-title mb-2" style="color: var(--text-primary);"><%= board.name %></h5>
      <p class="card-text text-muted small"><%= truncate(board.description, length: 100) %></p>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
      <span class="badge bg-secondary"><%= board.tasks.count %> tasks</span>
      <small class="text-muted"><%= board.owner.name %></small>
    </div>
  </div>
<% end %>
