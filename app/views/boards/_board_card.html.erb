<%= link_to board_path(board), class: "text-decoration-none" do %>
  <div class="card h-100">
    <h5 class="card-title mb-2" style="font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 500; color: var(--text-dark);"><%= board.name %></h5>
    <p class="text-muted mb-3" style="font-size: 0.85rem; line-height: 1.5;"><%= truncate(board.description, length: 100) %></p>
    <div class="d-flex justify-content-between align-items-center mt-auto">
      <span class="badge bg-secondary"><%= board.tasks.count %> tasks</span>
      <small class="text-muted" style="font-size: 0.75rem;"><%= board.owner.name %></small>
    </div>
  </div>
<% end %>
