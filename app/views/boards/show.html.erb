<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h1 class="mb-1"><%= @board.name %></h1>
    <p class="text-muted mb-1"><%= @board.description %></p>
    <small class="text-muted">Owned by <%= @board.owner.name %></small>
  </div>
  <div class="d-flex gap-2">
    <%= link_to "New Task", new_board_task_path(@board), class: "btn btn-success" %>
    <% if @board.owner == current_user %>
      <%= link_to "Edit", edit_board_path(@board), class: "btn btn-outline-secondary" %>
      <%= button_to "Delete", board_path(@board), method: :delete,
            class: "btn btn-outline-danger",
            data: { turbo_confirm: "Delete this board and all its tasks?" } %>
    <% end %>
  </div>
</div>

<div class="row g-3">
  <% status_icons = { "todo" => "&#9711;", "in_progress" => "&#9654;", "in_review" => "&#9673;", "done" => "&#10003;" } %>
  <% status_colors = { "todo" => "#8b949e", "in_progress" => "#58a6ff", "in_review" => "#d29922", "done" => "#3fb950" } %>
  <% %w[todo in_progress in_review done].each do |status| %>
    <div class="col-md-3">
      <div class="card kanban-column">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span style="color: <%= status_colors[status] %>;">
            <span style="margin-right: 6px;"><%= status_icons[status].html_safe %></span>
            <strong><%= status.titleize %></strong>
          </span>
          <span class="badge bg-secondary"><%= (@tasks_by_status[status] || []).count %></span>
        </div>
        <div class="card-body">
          <% (@tasks_by_status[status] || []).each do |task| %>
            <%= render "tasks/task_card", task: task, board: @board %>
          <% end %>
          <% if (@tasks_by_status[status] || []).empty? %>
            <p class="text-muted text-center small mt-4">No tasks</p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
