<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h1 style="font-size: 2.25rem; margin-bottom: 0.25rem;"><%= @board.name %></h1>
    <p class="text-muted mb-1" style="font-size: 0.9rem;"><%= @board.description %></p>
    <small class="text-muted" style="font-size: 0.75rem;">Owned by <%= @board.owner.name %></small>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <%= link_to "New Task", new_board_task_path(@board), class: "btn btn-success" %>
    <% if @board.owner == current_user %>
      <%= link_to "Edit", edit_board_path(@board), class: "btn btn-outline-secondary" %>
      <%= button_to "Delete", board_path(@board), method: :delete,
            class: "btn btn-outline-danger",
            data: { turbo_confirm: "Delete this board and all its tasks?" } %>
    <% end %>
  </div>
</div>

<div class="row g-3">
  <% column_labels = { "todo" => "To Do", "in_progress" => "In Progress", "in_review" => "In Review", "done" => "Done" } %>
  <% %w[todo in_progress in_review done].each do |status| %>
    <div class="col-md-3">
      <div class="card kanban-column">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h5 class="mb-0" style="font-size: 0.7rem;"><%= column_labels[status] %></h5>
          <span class="badge bg-secondary"><%= (@tasks_by_status[status] || []).count %></span>
        </div>
        <div class="card-body">
          <% (@tasks_by_status[status] || []).each do |task| %>
            <%= render "tasks/task_card", task: task, board: @board %>
          <% end %>
          <% if (@tasks_by_status[status] || []).empty? %>
            <p class="text-muted text-center mt-4" style="font-size: 0.8rem;">No tasks</p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
