<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1">Boards</h1>
    <p class="text-muted mb-0">Manage your projects and track progress</p>
  </div>
  <%= link_to "New Board", new_board_path, class: "btn btn-primary" %>
</div>

<div class="row g-4">
  <% @boards.each do |board| %>
    <div class="col-md-4">
      <%= render "board_card", board: board %>
    </div>
  <% end %>
</div>

<% if @boards.empty? %>
  <div class="text-center mt-5 py-5">
    <div style="font-size: 3rem; opacity: 0.3; margin-bottom: 1rem;">&#9776;</div>
    <h4 class="text-muted">No boards yet</h4>
    <p class="text-muted">Create your first board to start tracking tasks.</p>
    <%= link_to "Create Board", new_board_path, class: "btn btn-primary mt-2" %>
  </div>
<% end %>
