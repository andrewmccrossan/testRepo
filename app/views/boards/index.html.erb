<div class="d-flex justify-content-between align-items-end mb-5">
  <div>
    <h1 style="font-size: 2.5rem; margin-bottom: 0.25rem;">Boards</h1>
    <p class="text-muted mb-0" style="font-size: 0.9rem;">Your projects at a glance</p>
  </div>
  <%= link_to "New Board", new_board_path, class: "btn btn-primary" %>
</div>

<div class="row g-4">
  <% @boards.each do |board| %>
    <div class="col-md-4">
      <%= render "board_card", board: board %>
    </div>
  <% end %>
</div>

<% if @boards.empty? %>
  <div class="text-center mt-5 py-5">
    <p class="text-muted" style="font-size: 1.1rem;">No boards yet</p>
    <p class="text-muted" style="font-size: 0.85rem;">Create your first board to begin.</p>
    <%= link_to "Create Board", new_board_path, class: "btn btn-primary mt-2" %>
  </div>
<% end %>
