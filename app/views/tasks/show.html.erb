<div class="row g-4">
  <div class="col-md-8">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="mb-0"><%= @task.title %></h1>
      <div class="d-flex gap-2">
        <%= link_to "Edit", edit_board_task_path(@board, @task), class: "btn btn-outline-secondary btn-sm" %>
        <%= button_to "Delete", board_task_path(@board, @task), method: :delete,
              class: "btn btn-outline-danger btn-sm",
              data: { turbo_confirm: "Delete this task?" } %>
      </div>
    </div>

    <% if @task.description.present? %>
      <div class="card mb-4">
        <div class="card-body">
          <h6 class="text-muted text-uppercase small mb-3">Description</h6>
          <p class="mb-0" style="line-height: 1.7;"><%= simple_format(@task.description) %></p>
        </div>
      </div>
    <% end %>

    <div class="card mb-4">
      <div class="card-body">
        <div class="row text-center">
          <div class="col-md-4">
            <small class="text-muted text-uppercase d-block mb-1">Status</small>
            <% status_colors = { "todo" => "secondary", "in_progress" => "info", "in_review" => "warning", "done" => "success" } %>
            <span class="badge bg-<%= status_colors[@task.status] %>"><%= @task.status.titleize %></span>
          </div>
          <div class="col-md-4">
            <small class="text-muted text-uppercase d-block mb-1">Priority</small>
            <% priority_colors = { "low" => "success", "medium" => "info", "high" => "warning", "urgent" => "danger" } %>
            <span class="badge bg-<%= priority_colors[@task.priority] %>"><%= @task.priority.upcase %></span>
          </div>
          <div class="col-md-4">
            <small class="text-muted text-uppercase d-block mb-1">Due Date</small>
            <span class="<%= @task.due_date && @task.due_date < Date.current ? 'text-danger' : '' %>">
              <%= @task.due_date&.strftime("%B %d, %Y") || "Not set" %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <h5 class="mb-3">Update Status</h5>
    <div class="d-flex gap-2 mb-4 flex-wrap">
      <% %w[todo in_progress in_review done].each do |status| %>
        <%= button_to status.titleize,
              update_status_board_task_path(@board, @task),
              params: { status: status },
              method: :patch,
              class: "btn btn-sm #{@task.status == status ? 'btn-primary' : 'btn-outline-secondary'}" %>
      <% end %>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <strong>Assignees</strong>
      </div>
      <ul class="list-group list-group-flush">
        <% @task.assignments.includes(:user).each do |assignment| %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span><%= assignment.user.name %></span>
            <%= button_to "Remove", board_task_assignment_path(@board, @task, assignment),
                  method: :delete, class: "btn btn-outline-danger btn-sm" %>
          </li>
        <% end %>
        <% if @task.assignees.empty? %>
          <li class="list-group-item text-muted">No assignees</li>
        <% end %>
      </ul>
      <div class="card-body">
        <%= form_with url: board_task_assignments_path(@board, @task), method: :post, class: "d-flex gap-2" do |f| %>
          <%= f.select :user_id, User.where.not(id: @task.assignee_ids).map { |u| [u.name, u.id] },
                { prompt: "Select user..." }, class: "form-select form-select-sm" %>
          <%= f.submit "Assign", class: "btn btn-sm btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= link_to "Back to Board", board_path(@board), class: "btn btn-outline-secondary mt-4" %>
