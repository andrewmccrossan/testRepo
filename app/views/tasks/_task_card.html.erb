<div class="card mb-2">
  <div class="card-body p-2">
    <div class="d-flex justify-content-between align-items-start">
      <%= link_to task.title, board_task_path(board, task), class: "text-decoration-none fw-bold small" %>
      <% priority_colors = { "low" => "success", "medium" => "info", "high" => "warning", "urgent" => "danger" } %>
      <span class="badge bg-<%= priority_colors[task.priority] %>"><%= task.priority.capitalize %></span>
    </div>
    <% if task.due_date %>
      <small class="<%= task.due_date < Date.current ? 'text-danger' : 'text-muted' %>">
        Due: <%= task.due_date.strftime("%b %d") %>
      </small>
    <% end %>
    <% if task.assignees.any? %>
      <div class="mt-1">
        <% task.assignees.each do |assignee| %>
          <span class="badge bg-secondary"><%= assignee.name.split.map(&:first).join %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
